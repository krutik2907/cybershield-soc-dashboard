# ============================================
# CyberShield SOC Dashboard — Environment Config
# ============================================
# Copy this file to .env and fill in your API keys.
# NEVER commit .env to version control!
# ============================================

# --- API Keys ---

# VirusTotal v3 API Key (https://www.virustotal.com/gui/join-us)
VT_API_KEY=

# AbuseIPDB v2 API Key (https://www.abuseipdb.com/register)
ABUSEIPDB_API_KEY=

# ipinfo.io Token (https://ipinfo.io/signup)
IPINFO_TOKEN=

# AlienVault OTX API Key (https://otx.alienvault.com/api)
OTX_API_KEY=

# --- Server Settings ---

# Server port
PORT=3000

# Set to 'production' for stricter security (locked CORS, no stack traces)
NODE_ENV=development

# Allowed origin for CORS in production (e.g., https://yourdomain.com)
ALLOWED_ORIGIN=
